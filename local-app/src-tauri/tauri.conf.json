{
  "build": {
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "devPath": "http://localhost:5173",
    "frontendDist": "../frontend/dist",
    "features": []
  },
  "app": {
    "windows": [
      {
        "title": "XianZhu",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data: asset: https://asset.localhost; connect-src 'self' https: wss:; font-src 'self' data:; media-src 'self' https://asset.localhost asset: blob:"
    }
  },
  "package": {
    "productName": "xianzhu",
    "version": "0.2.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "save": true
      },
      "fs": {
        "all": false,
        "writeFile": true,
        "scope": ["$DOCUMENT/**", "$DOWNLOAD/**", "$DESKTOP/**", "$HOME/**"]
      },
      "notification": {
        "all": true
      },
      "http": {
        "all": true,
        "scope": ["https://**", "http://**"]
      },
      "clipboard": {
        "all": true
      },
      "globalShortcut": {
        "all": true
      },
      "process": {
        "all": true
      }
    },
    "protocol": {
      "asset": true,
      "assetScope": ["**"]
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.xianzhu.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "resources/python.tar.gz",
        "resources/wheels/*"
      ]
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data: asset: https://asset.localhost; connect-src 'self' https: wss:; font-src 'self' data:; media-src 'self' https://asset.localhost asset: blob:"
    }
  }
}
