{
  "build": {
    "beforeBuildCommand": "cd frontend && npx vite build",
    "beforeDevCommand": "",
    "devPath": "../frontend/dist",
    "distDir": "../frontend/dist"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "shell": {
        "all": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://**", "https://**"]
      },
      "protocol": {
        "asset": true,
        "assetScope": ["**"]
      }
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "XianZhu",
        "width": 1200,
        "fileDropEnabled": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: tauri: asset: https://asset.localhost; connect-src 'self' https: wss: http:; img-src 'self' data: blob: asset: https://asset.localhost https://*; media-src 'self' data: blob: asset: https://asset.localhost"
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.xianzhu.app",
      "resources": [
        "bundled-skills/**/*"
      ],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  },
  "package": {
    "productName": "XianZhu",
    "version": "0.1.0"
  }
}
