{
  "build": {
    "beforeBuildCommand": "cd frontend && npx vite build",
    "beforeDevCommand": "",
    "devPath": "../frontend/dist",
    "distDir": "../frontend/dist"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "shell": {
        "all": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://**", "https://**"]
      },
      "protocol": {
        "asset": true,
        "assetScope": ["**"]
      }
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "XianZhuClaw",
        "width": 1200,
        "fileDropEnabled": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: tauri: asset: https://asset.localhost; connect-src 'self' https: wss: http:; img-src 'self' data: blob: asset: https://asset.localhost https://*; media-src 'self' data: blob: asset: https://asset.localhost"
    },
    "macOSPrivateApi": true,
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://zys-openclaw.com/api/v1/update/check?target={{target}}&current_version={{current_version}}",
        "https://raw.githubusercontent.com/zyswork/xianzhu-claw/main/updater/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDODRFRkE4MURFMjM0MDAKUldRQU5PSWRxTytFekJMYjh0WVRheFVzVDJzWWhMQXBNOW1Rc0NHVnFha0FDNnhRaGZqUnZ1ZlEK"
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.xianzhu.app",
      "resources": [
        "bundled-skills/**/*",
        "resources/python.tar.gz",
        "resources/wheels/*"
      ],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  },
  "package": {
    "productName": "XianZhuClaw",
    "version": "1.1.0"
  }
}
